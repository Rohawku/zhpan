# Copy this to `.env` and fill in your actual keys.
# `.env` is gitignored — never commit real keys.

# ─── Chinese frontier APIs ────────────────────────────────
# 阿里 Qwen via DashScope (https://dashscope.console.aliyun.com)
DASHSCOPE_API_KEY=sk-...

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...

# 智谱 GLM-4 (https://open.bigmodel.cn)
ZHIPU_API_KEY=...

# 字节豆包 via Volcengine Ark (https://www.volcengine.com/product/ark)
ARK_API_KEY=...

# ─── Cross-lingual control (optional) ─────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Run config ───────────────────────────────────────────
ZHPAN_BUDGET_USD=30
ZHPAN_LOG_LEVEL=INFO
ZHPAN_CACHE_ENABLED=true
